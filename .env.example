# ============================================================
# Arc WorkNet — Environment Variables Template
# Copy to .env and fill in your values.
# ============================================================

# ---------- Supabase (REQUIRED) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Arc Chain ----------
NEXT_PUBLIC_ARC_CHAIN_ID=5042002
NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_WS_URL=wss://rpc.testnet.arc.network
NEXT_PUBLIC_ARC_EXPLORER_URL=https://testnet.arcscan.app

# ---------- Contract Addresses ----------
NEXT_PUBLIC_ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
NEXT_PUBLIC_ERC8183_CONTRACT_ADDRESS=0xFD9C4D6fe5a770f148C0Cc49Bc293015525BA955
ERC8004_IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
ERC8004_REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713
ERC8004_VALIDATION_REGISTRY=0x8004Cb1BF31DAf7788923b405b754f57acEB4272

# ---------- Privy Auth (REQUIRED) ----------
# Get from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# ---------- Security & Encryption ----------
DATA_ENCRYPTION_KEY=
ADMIN_API_SECRET=
CIRCLE_WEBHOOK_SECRET=

# ---------- Circle (optional) ----------
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_APP_KIT_KEY=
# Client-side on-ramp. Set BOTH to enable the "Add funds" buy-USDC flow.
NEXT_PUBLIC_CIRCLE_APP_KIT_KEY=
NEXT_PUBLIC_CIRCLE_ONRAMP_URL=

# ---------- AI & Platform ----------
AI_PROVIDER_API_KEY=
PLATFORM_FEE_BPS=100
PLATFORM_FEE_RECIPIENT_ADDRESS=

# ---------- Feature Flags ----------
# Off by default for production. Set true only for local demos.
NEXT_PUBLIC_ENABLE_DEMO_DATA=false
# Best-effort ERC-8004 reputation write on agent job completion. Requires a
# deployed, compatible ReputationRegistry. Failures are swallowed.
NEXT_PUBLIC_ENABLE_ONCHAIN_REPUTATION=false

# ---------- Cypress Test Wallets (TESTING ONLY) ----------
# Private keys for dummy client/worker wallets used in Cypress E2E tests.
# These wallets should only hold testnet tokens. Never use real wallets.
# Generate with: node -e "import('viem/accounts').then(m=>console.log(m.generatePrivateKey()))"
CYPRESS_TEST_CLIENT_PRIVATE_KEY=
CYPRESS_TEST_WORKER_PRIVATE_KEY=
