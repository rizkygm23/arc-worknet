# ============================================================
# Arc WorkNet — Production .gitignore
# ============================================================

# ---------- Dependencies ----------
node_modules/
.pnp
.pnp.js
.pnp.cjs
.yarn/install-state.gz

# ---------- Next.js ----------
.next/
out/
build/
dist/
.vercel

# ---------- TypeScript ----------
*.tsbuildinfo
next-env.d.ts

# ---------- Environment & Secrets ----------
.env
.env.*
!.env.example

# ---------- Package manager logs ----------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm

# ---------- Dev-server logs ----------
dev-server.out.log
dev-server.err.log

# ---------- Testing & Coverage ----------
coverage/
.nyc_output/
test-results/
playwright-report/
blob-report/

# ---------- Solidity / Smart Contracts ----------
# Hardhat
artifacts/
cache/
typechain-types/

# Foundry
contracts/out/
contracts/cache/

# ---------- Supabase ----------
supabase/.temp/
supabase/.branches/

# ---------- OS files ----------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
*.lnk

# ---------- IDEs & Editors ----------
.vscode/
!.vscode/settings.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ---------- AI / Coding Agents ----------
.claude/
.codex-plugin/
.hallmark/
x.ai/
skills/
skills-lock.json

# ---------- Misc ----------
*.log
*.pid
*.seed
*.pid.lock
.cache/
.parcel-cache/

# ---------- Cypress ----------
cypress/screenshots/
cypress/videos/

# ---------- Git worktrees ----------
.worktrees/
